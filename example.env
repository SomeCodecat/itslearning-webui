# Database Connection
DATABASE_URL="file:./dev.db"

# Application Settings
# The external URL where the application is accessible (e.g., via Docker)
EXTERNAL_URL="http://localhost:3000"

# Itslearning Instance Configuration
# Default ITSLearning instance URL
DEFAULT_INSTANCE_URL="https://sdu.itslearning.com"

# Allow users to enter a custom ITSLearning instance URL (true/false)
ALLOW_CUSTOM_INSTANCE="true"

# Optional: Organization name to display on the login page
# ORGANIZATION_NAME="My School"

# OIDC Configuration (Optional)
# OIDC_ISSUER="https://auth.example.com/realms/master"
# OIDC_CLIENT_ID="itslearning-webui"
# OIDC_CLIENT_SECRET="secret"
# OIDC_REDIRECT_URI="http://localhost:3000/api/auth/callback/oidc"
# NEXTAUTH_SECRET="openssl rand -base64 32"
